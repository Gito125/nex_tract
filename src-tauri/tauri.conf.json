{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nextract",
  "version": "1.14.0",
  "identifier": "com.nextract.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3004",
    "frontendDist": "../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "Nextract",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/nextract-server"
    ],
    "resources": [
      "resources/*"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ],
        "section": "utils",
        "priority": "optional"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3"
        ],
        "release": "1"
      }
    },
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": [
          "English"
        ],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Gito125/nex_tract/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4MTE3QUFFMDQ0OTc2RUYKUldUdmRra0Vybm9SV0NxY3RJNm1FT2diNXF1T3hVYU9yYnRnNU8zQk5vRWRaMzdNckR0d21scU0K"
    }
  }
}
