{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nextract",
  "version": "1.9.1",
  "identifier": "com.nextract.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "cd ../web && pnpm build",
    "devUrl": "http://localhost:3004",
    "frontendDist": "../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "Nextract",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/nextract-server"
    ],
    "resources": [
      "resources/ffmpeg",
      "resources/ffmpeg.exe"
    ]
  }
}
